[flake8]
# ──────────────────────────────────────────────────────────────────────────────
# CoveLegal flake8 configuration
# ──────────────────────────────────────────────────────────────────────────────
# Line length – matches black default
max-line-length = 120

# Exclude directories
exclude =
    venv,
    .venv,
    __pycache__,
    .git,
    migrations,
    *.egg-info,
    dist,
    build

# ──────────────────────────────────────────────────────────────────────────────
# Ignored codes
#
# This project uses Black for code formatting. Black handles all whitespace /
# indentation / blank-line rules, so we suppress the E1xx/E2xx/E3xx/W style
# codes that Black manages. We keep the critical codes:
#   E9xx  – Syntax errors (always fatal)
#   F4xx  – Import errors (unused, undefined)
#   F8xx  – Undefined names
#   W605  – Invalid escape sequence
# ──────────────────────────────────────────────────────────────────────────────
ignore =
    # Indentation / whitespace (Black-managed)
    E1,
    E2,
    # Blank lines around functions/classes (Black-managed)
    E3,
    # Statement/import style (Black-managed)
    E4,
    E5,
    E7,
    # Line-too-long handled by max-line-length above
    E501,
    # Whitespace before/after colon (Black-managed)
    W,
    # Walrus operator compat
    E231,

# Per-file ignores for generated / vendored code
per-file-ignores =
    # Test files: allow undefined names and long lines
    tests/*.py: F811, F841
    # Routes files: allow long lines for API response schemas
    */routes.py: E501
