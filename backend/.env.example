# Cove Legal Tech – Environment Variables Template
# COPY THIS FILE to .env and fill in REAL values
# NEVER commit .env to version control

# ── Environment ────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=cove_db
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10

# ── Authentication ─────────────────────────────────────────────────────────
# CRITICAL: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_64_CHARACTER_HEX_STRING_MINIMUM
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://app.cove.zm,https://staging.cove.zm

# ── Trusted Hosts ─────────────────────────────────────────────────────────
TRUSTED_HOSTS=app.cove.zm,staging.cove.zm

# ── AI / LLM ───────────────────────────────────────────────────────────────
EMERGENT_LLM_KEY=REPLACE_WITH_LLM_API_KEY

# ── Payment Providers ────────────────────────────────────────────────────
CGRATE_BASE_URL=https://api.cgrate.com
CGRATE_API_KEY=REPLACE_WITH_CGRATE_KEY
CGRATE_SECRET=REPLACE_WITH_CGRATE_SECRET

DPO_BASE_URL=https://secure.3gdirectpay.com
DPO_COMPANY_TOKEN=REPLACE_WITH_DPO_TOKEN

FLUTTERWAVE_SECRET_KEY=REPLACE_WITH_FLW_SECRET
FLUTTERWAVE_PUBLIC_KEY=REPLACE_WITH_FLW_PUBLIC

# ── AWS S3 ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET
AWS_REGION=af-south-1
S3_BUCKET_NAME=cove-vdr-documents

# ── Sentry ─────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Zambia-Specific ────────────────────────────────────────────────────────
DEFAULT_CURRENCY=ZMW
LOW_BANDWIDTH_OPTIMIZATION=true
