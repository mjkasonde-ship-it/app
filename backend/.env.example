# ---------------------------------------------------------------------------
# Cove Legal Tech – Backend Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file.
# ---------------------------------------------------------------------------

# ── Database ──────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=cove_db

# ── Authentication (JWT) ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. No wildcards in production.
CORS_ORIGINS=http://localhost:3000

# ── AI / LLM ──────────────────────────────────────────────────────────────
EMERGENT_LLM_KEY=REPLACE_WITH_YOUR_LLM_KEY

# ── Sentry (optional – leave blank to disable) ────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Payment providers ─────────────────────────────────────────────────────
# cGrate
CGRATE_BASE_URL=https://api.cgrate.com
CGRATE_API_KEY=REPLACE_WITH_CGRATE_KEY
CGRATE_SECRET=REPLACE_WITH_CGRATE_SECRET

# DPO Pay
DPO_BASE_URL=https://secure.3gdirectpay.com
DPO_COMPANY_TOKEN=REPLACE_WITH_DPO_TOKEN

# Flutterwave
FLUTTERWAVE_SECRET_KEY=REPLACE_WITH_FW_SECRET
FLUTTERWAVE_PUBLIC_KEY=REPLACE_WITH_FW_PUBLIC

# ── AWS S3 (for VDR file storage) ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET
AWS_REGION=af-south-1
S3_BUCKET_NAME=cove-vdr-documents
